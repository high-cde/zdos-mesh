class Node:
    def __init__(self, id):
        self.id = id

    def receive(self, msg):
        print("[Node", self.id, "]", msg)

class Mesh:
    def __init__(self):
        self.nodes = []

    def add(self, node):
        self.nodes.append(node)

    def broadcast(self, msg):
        for n in self.nodes:
            n.receive(msg)
