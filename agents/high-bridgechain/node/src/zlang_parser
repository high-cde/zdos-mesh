#[derive(Debug)]
pub enum ZAst {
    Number(i64),
    Add(Box<ZAst>, Box<ZAst>),
}

pub fn parse(expr: &str) -> Result<ZAst, String> {
    let parts: Vec<&str> = expr.split('+').collect();

    if parts.len() == 2 {
        let a = parts[0].trim().parse::<i64>().map_err(|_| "bad number")?;
        let b = parts[1].trim().parse::<i64>().map_err(|_| "bad number")?;

        return Ok(ZAst::Add(
            Box::new(ZAst::Number(a)),
            Box::new(ZAst::Number(b)),
        ));
    }

    Err("unsupported expression".into())
}
